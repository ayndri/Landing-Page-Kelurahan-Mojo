APP_NAME="Kelurahan Mojo 2"
APP_ENV=production
APP_KEY=                          # ← isi dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://namadomain.com    # ← ganti dengan domain kamu

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanelusername_kknnr  # ← ganti sesuai nama DB di cPanel
DB_USERNAME=cpanelusername_user   # ← ganti sesuai username DB di cPanel
DB_PASSWORD=password_db_kamu      # ← ganti

SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
